  { cat:'Instalaciones', tipo:'instalaciones', title:'Nuestras Instalaciones', desc:'Contamos con un espacio amplio, limpio y equipado para la práctica de Karate Do y Pilates. Un ambiente seguro y profesional para toda la familia.',   video:'https://www.youtube.com/embed/tMdtxUge06s' },

  { cat:'Implementos', tipo:'implementos', title:'Implementos de Entrenamiento', desc:'Balones, bosu, bandas elásticas, paletas y más. Equipamiento variado para entrenamientos dinámicos y funcionales.',   video:'https://www.youtube.com/embed/tMdtxUge06s' },
  { cat:'Torneos KSK', tipo:'torneos', title:'Torneos KSK', desc:'Participamos en torneos organizados por la comunidad KSK, donde nuestros alumnos ponen a prueba su técnica y espíritu deportivo.',   video:'https://www.youtube.com/embed/tMdtxUge06s' },
